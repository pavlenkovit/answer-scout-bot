# Telegram (BotFather)
TELEGRAM_BOT_TOKEN=

# Optional: legacy single-chat mode removed — each user chats in their own Telegram chat.

# OpenRouter
OPENROUTER_API_KEY=

# Apify
APIFY_API_TOKEN=

# Supabase (Dashboard → Project Settings → API)
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# Server-side bot: use "service_role" secret (not the anon key), keep it private.
SUPABASE_SERVICE_ROLE_KEY=
# Alternative if you configure RLS/policies yourself:
# SUPABASE_ANON_KEY=
