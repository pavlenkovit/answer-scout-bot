# Telegram (BotFather)
TELEGRAM_BOT_TOKEN=
# Стоимость одного запуска «Найти новые вопросы» в Telegram Stars (XTR). В @BotFather → бот → Payments включи приём Stars.
SCAN_COST_STARS=5
# Сколько первых успешных поисков бесплатно (после каждого успешного прогона счётчик в Supabase +1).
FREE_SCANS_COUNT=3

# Optional: legacy single-chat mode removed — each user chats in their own Telegram chat.

# OpenRouter
OPENROUTER_API_KEY=

# Apify
APIFY_API_TOKEN=

# Supabase (Dashboard → Project Settings → API → Legacy service_role)
# На Railway/Render/Fly задай те же переменные в UI хоста — сервер не читает твой локальный .env.
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# Server-side bot: use "service_role" secret (not the anon key), keep it private.
SUPABASE_SERVICE_ROLE_KEY=